# Optional AI assist configuration.
# If unset, Inkforge falls back to the built-in local continuity engine.
# Cheapest strong setup: use an OpenAI-compatible gateway such as OpenRouter
# and point it at a fast low-cost model.
# OPENAI_SITE_URL and OPENAI_SITE_NAME are useful for providers such as
# OpenRouter that support ranking or attribution headers.
# OPENAI_TIMEOUT_MS controls how long the route waits before falling back
# to the local continuity engine.

OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini
OPENAI_SITE_URL=https://your-production-domain.example
OPENAI_SITE_NAME=Inkforge Studio
OPENAI_TIMEOUT_MS=45000